<UserControl x:Class="MyProject2.Admin.Views.UCUrunListesiAllFilterFrm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MyProject2.Admin.Views"
             xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- HEADER -->
            <RowDefinition Height="Auto"/>
            <!-- EKLE -->
            <RowDefinition Height="Auto"/>
            <!-- GENEL FILTER + Toggle Filtre -->
            <RowDefinition Height="*"/>
            <!-- DATAGRID + Filtre -->
            <RowDefinition Height="Auto"/>
            <!-- PAGING -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#7364BF" CornerRadius="10 10 0 0" Padding="12">
            <TextBlock Text="Ürünler Tüm Filtreler"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- EKLE -->
        <Border Grid.Row="1" Background="White" Padding="10">
            <Button Style="{StaticResource addButton}" Click="BtnEkle_Click">
                <StackPanel Orientation="Horizontal">
                    <Icon:PackIconMaterial Kind="Plus" Width="12" Height="12" Margin="0 0 8 0"/>
                    <TextBlock Text="Ekle"/>
                </StackPanel>
            </Button>
        </Border>

        <Grid Grid.Row="2" Background="White" Margin="0 0 0 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Üst satır: Toplam + Toggle + Arama -->
                <RowDefinition Height="Auto"/>
                <!-- Alt satır: Detay filtre -->
            </Grid.RowDefinitions>

            <!-- Üst satır -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10 5 0 5">
                    <TextBlock Text="{Binding ToplamText}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <ToggleButton x:Name="BtnToggleFilter" Content="Filtrele" Width="80" Margin="10 0 0 0"/>
                </StackPanel>

                <TextBlock Text="Ara" FontWeight="SemiBold" FontSize="13"
                  Margin="0 0 20 0" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                <TextBox x:Name="TxtFilter"
                 Grid.Column="1"
                 Width="220"
                 Margin="0 0 10 0"
                 VerticalAlignment="Center"
                 TextChanged="TxtFilter_TextChanged"
                 Style="{StaticResource textboxFilter}"/>



            </Grid>

            <!-- Alt satır: Filtre kutuları -->
            <Grid Grid.Row="1"
          Margin="0 5 0 0"
          Visibility="{Binding IsChecked, ElementName=BtnToggleFilter, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"/>
                <TextBox x:Name="TxtID" Grid.Column="1" Margin="2" TextChanged="FilterChanged"    Style="{StaticResource textboxFilter}"/>
                <TextBox x:Name="TxtKategori" Grid.Column="2" Margin="2" TextChanged="FilterChanged"    Style="{StaticResource textboxFilter}"/>
                <TextBox x:Name="TxtTanim" Grid.Column="3" Margin="2" TextChanged="FilterChanged"    Style="{StaticResource textboxFilter}"/>
                <TextBox x:Name="TxtBarkod" Grid.Column="4" Margin="2" TextChanged="FilterChanged"    Style="{StaticResource textboxFilter}"/>
                <TextBox x:Name="TxtSKT" Grid.Column="5" Margin="2" TextChanged="FilterChanged"    Style="{StaticResource textboxFilter}"/>
                <TextBox x:Name="TxtMuhafaza" Grid.Column="6" Margin="2" TextChanged="FilterChanged"    Style="{StaticResource textboxFilter}"/>
                <TextBlock Grid.Column="7"/>
            </Grid>
        </Grid>

        <!-- DATAGRID -->
        <Border Grid.Row="3" Background="White" CornerRadius="0 0 20 10" Padding="10">
            <Grid>
                <DataGrid x:Name="GridUrunler"
                          ItemsSource="{Binding Urunler}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          ScrollViewer.VerticalScrollBarVisibility="Hidden"
                          ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          RowStyle="{DynamicResource DataGridRowStyle1}"
                          Style="{DynamicResource DataGridStyle1}"
                          CellStyle="{DynamicResource DataGridCellStyle1}"
                          ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle1}"
                          IsReadOnly="True">

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="60">
                            <DataGridTemplateColumn.Header>
                                <CheckBox Style="{StaticResource CheckBoxStyle1}" Margin="5 0 0 0"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox HorizontalAlignment="Center" Style="{StaticResource CheckBoxStyle1}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Ürün No" Binding="{Binding UrunID}" Width="*"/>
                        <DataGridTextColumn Header="Kategori" Binding="{Binding KategoriTanim}" Width="*"/>
                        <DataGridTextColumn Header="Tanım" Binding="{Binding Tanim}" Width="*"/>
                        <DataGridTextColumn Header="Barkod" Binding="{Binding Barkod}" Width="*"/>
                        <DataGridTextColumn Header="SKT" Binding="{Binding SKTGunSayisi}" Width="*"/>
                        <DataGridTextColumn Header="Muhafaza" Binding="{Binding MuhafazaTanim}" Width="*"/>

                        <DataGridTemplateColumn Header="İşlemler" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- PAGING -->
        <Border Grid.Row="4"
                Background="White"
                BorderBrush="#dee4ec"
                BorderThickness="1"
                CornerRadius="0 0 12 12"
                Padding="5"
                HorizontalAlignment="Right"
                Margin="0 5 5 5">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource pagingButton}" Click="Prev_Click">
                    <Icon:PackIconMaterial Kind="ChevronLeft"/>
                </Button>

                <ItemsControl ItemsSource="{Binding Pages}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}" Click="Page_Click" Style="{StaticResource pagingButton}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Style="{StaticResource pagingButton}" Click="Next_Click">
                    <Icon:PackIconMaterial Kind="ChevronRight"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>