<Window x:Class="MyProject2.Admin.Views.WinLoginFrm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyProject2.Admin.Views"
               Title="Login"
        Height="360"
        Width="340"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Border CornerRadius="20"
            Padding="30"
            Background="#2A2A40">

        <Grid>

            <!-- Kapat Butonu -->
            <Button Content="✕"
                    Width="30"
                    Height="30"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    Foreground="White"
                    BorderThickness="0"
                    Click="BtnClose_Click"/>

            <StackPanel Margin="0,10,0,0">

                <!-- Başlık -->
                <TextBlock Text="My Project"
                           FontSize="24"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Kullanıcı -->
                <TextBox Height="45"
                         Margin="0,10"
                         Background="#1E1E2F"
                         Foreground="White"
                         BorderBrush="#6C5CE7"
                         BorderThickness="1"
                         Padding="9" 
                         FontSize="16"
                         VerticalContentAlignment="Center"
                         x:Name="txtKullaniciAdi"
                         Text="{Binding Kullanici.KullaniciAdi}"/>

                <!-- Şifre -->
                <Grid Margin="0,8">

                    <PasswordBox x:Name="pwdSifre"
                                 Height="45"
                                 Margin="0,10"
                                 Background="#1E1E2F"
                                 Foreground="White"
                                 BorderBrush="#6C5CE7"
                                 BorderThickness="1"
                                 Padding="9"
                                 FontSize="16"
                                 VerticalContentAlignment="Center"/>

                    <TextBox x:Name="txtSifre"
                             Height="45"
                             Margin="0,10"
                             Background="#1E1E2F"
                             Foreground="White"
                             BorderBrush="#6C5CE7"
                             BorderThickness="1"
                             Padding="9"
                             FontSize="16"
                             VerticalContentAlignment="Center"
                             Visibility="Collapsed"/>

                    <!-- Göz ikon -->
                    <Button Content="👁"
                            Width="40"
                            Height="45"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="BtnShowPassword_Click"/>
                </Grid>

                <!-- Giriş -->
                <Button Content="Giriş Yap"
                        Height="42" 
                        Margin="40,20,40,0"
                        Click="BtnGiris_Click"
                        Background="#6C5CE7"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        Cursor="Hand"/>

            </StackPanel>

        </Grid>
    </Border>
</Window>