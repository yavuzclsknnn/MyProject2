<Window x:Class="MyProject2.Admin.Views.WinKullaniciEditFrm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyProject2.Admin.Views"
        mc:Ignorable="d"
        Title="WinKullaniciEditFrm"         
        Height="600"
        Width="450" 
        WindowStyle="None"
        Background="{x:Null}" 
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize">



    <Border Style="{StaticResource PopupPage_CardStyle}"
            Width="430">

        <Grid>

            <!-- ANA YAPI -->
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    CornerRadius="18,18,0,0"
                    Background="{StaticResource PopupPage_PrimaryGradient}">

                <TextBlock Text="Kullanici Bilgisi"
                           Foreground="White"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="15,0"/>
            </Border>

            <!-- FORM -->
            <Grid Grid.Row="1"
                  Margin="20,15,20,0"
                  x:Name="PanelBilgi">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- KullaniciAdi -->
                <TextBlock Text="KullaniciAdi :"
                           Grid.Row="0" Grid.Column="0"
                           VerticalAlignment="Center"
                           Style="{StaticResource PopupPage_LabelStyle}"
                           Margin="0,10,10,0"/>

                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding Current.KullaniciAdi,
                                Mode=TwoWay,
                                UpdateSourceTrigger=PropertyChanged,
                                ValidatesOnDataErrors=True}"
                         Style="{StaticResource PopupPage_TextBoxStyle}"
                         Margin="0,10,0,0"/>

                <!-- Email -->
                <TextBlock Text="Email :"
                           Grid.Row="1" Grid.Column="0"
                           VerticalAlignment="Center"
                           Style="{StaticResource PopupPage_LabelStyle}"
                           Margin="0,10,10,0"/>

                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding Current.Email}"
                         Style="{StaticResource PopupPage_TextBoxStyle}"
                         Margin="0,10,0,0"/>

                <!-- Sifre -->
                <TextBlock Text="Sifre :"
                           Grid.Row="2" Grid.Column="0"
                           VerticalAlignment="Center"
                           Style="{StaticResource PopupPage_LabelStyle}"
                           Margin="0,10,10,0"/>

                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding Current.Sifre,
                                Mode=TwoWay,
                                UpdateSourceTrigger=PropertyChanged,
                                ValidatesOnDataErrors=True}"
                         MaxLength="10"
                         Style="{StaticResource PopupPage_TextBoxStyle}"
                         Margin="0,10,0,0"/>

                <!-- Aktif -->
                <TextBlock Text="Aktif :"
                           Grid.Row="3" Grid.Column="0"
                           VerticalAlignment="Center"
                           Style="{StaticResource PopupPage_LabelStyle}"
                           Margin="0,15,10,0"/>

                <CheckBox Grid.Row="3" Grid.Column="1"
                          IsChecked="{Binding Current.Aktif, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource CheckBoxStyle1}"
                          Margin="0,15,0,0"/>

            </Grid>

            <!-- BUTONLAR -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="20,10,20,20">

                <Button Content="Kaydet"
                  Command="{Binding SaveCommand}"
                  x:Name="BtnKaydet"
                  Click="BtnKaydet_Click"
                  Width="100"
                  Style="{StaticResource PopupPage_PrimaryButtonStyle}"/>

                <Button Content="İptal"
                  Command="{Binding CancelCommand}" 
                   x:Name="BtnIptal"
                  Click="BtnIptal_Click"
                  Width="100"
                  Margin="10,0,0,0"
                  Style="{StaticResource PopupPage_SecondaryButtonStyle}"/>

            </StackPanel>

        </Grid>

    </Border>
</Window>