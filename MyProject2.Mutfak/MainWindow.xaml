<Window x:Class="MyProject2.Mutfak.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyProject2.Mutfak" 
        mc:Ignorable="d"
        Title="Mutfak Etiket Sistemi"
        WindowState="Maximized"
        Background="#F4F6F8">

    <Grid>

        <!-- ÜST BAR -->
        <Border Background="#2C3E50" Height="70" VerticalAlignment="Top">
            <Grid>
                <TextBlock Text="MUTFAK ETİKET SİSTEMİ"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>

                <TextBlock Text="{Binding Saat}"
                           Foreground="White"
                           FontSize="18"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>
            </Grid>
        </Border>

        <!-- ANA ALAN -->
        <Grid Margin="0,70,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- KATEGORİ PANEL -->
            <Border Grid.Column="0" Background="White" Margin="10" CornerRadius="10">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="kategoriPanel" Margin="10"/>
                </ScrollViewer>

            </Border>

            <!-- ÜRÜN PANEL -->
            <Border Grid.Column="1" Background="White" Margin="10" CornerRadius="10">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <WrapPanel x:Name="urunPanel" Margin="10"/>
                </ScrollViewer>

            </Border>

        </Grid>

    </Grid>
</Window>